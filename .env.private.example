IS_PRODUCTION=false # obviously, set to true in prod.

# Comma-separated Discord user IDs, global admins across api/ama-bot. Also doubles as the
# Grafana Discord-login allowlist - ./compose derives GRAFANA_OAUTH_ROLE_ATTRIBUTE_PATH from
# this at invocation time, so there's one list to keep updated, not two.
ADMINS=000000000000000000

ENCRYPTION_KEY=boop # generate using node -e "console.log(require('crypto').randomBytes(32).toString('base64'));"
OAUTH_DISCORD_CLIENT_SECRET=boop # from your discord application page

LOCAL_DATABASE_PORT=5432
LOCAL_GRAFANA_PORT=3000
LOCAL_DOZZLE_PORT=8080

GRAFANA_ADMIN_PASSWORD=boop # local break-glass login only, real auth is Discord OAuth via ADMINS
ALERTS_DISCORD_WEBHOOK_URL=boop # Discord webhook Grafana alerting posts to

AMA_BOT_TOKEN=boop
MODMAIL_BOT_TOKEN=boop

# Dozzle's webhook destination points at our /v3/logs/webhook route instead of Discord directly, so
# we can prettify the raw JSON it embeds before relaying to the real Discord webhook below.
DOZZLE_WEBHOOK_SECRET=boop # sent by Dozzle via a custom "X-Webhook-Secret" header on the destination, generate using node -e "console.log(require('crypto').randomBytes(32).toString('base64'));"
DOZZLE_WEBHOOK_DISCORD_ID=000000000000000000 # id from the real Discord webhook URL
DOZZLE_WEBHOOK_DISCORD_TOKEN=boop # token from the real Discord webhook URL

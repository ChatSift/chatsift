{
	"$schema": "http://json.schemastore.org/package",
	"name": "chatsift",
	"packageManager": "yarn@4.17.1",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/public/*",
		"packages/private/*",
		"services/*"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chatsift/chatsift.git"
	},
	"bugs": {
		"url": "https://github.com/chatsift/chatsift/issues"
	},
	"homepage": "https://github.com/chatsift/chatsift#readme",
	"scripts": {
		"build": "turbo run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:nocov": "vitest run --coverage.enabled=false",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint:fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"clean": "turbo run clean && rimraf **/node_modules",
		"clean:deps": "rimraf **/node_modules",
		"dev:api": "turbo run build --filter=@chatsift/api && dotenv -e .env.private -e .env.public -- node --enable-source-maps ./services/api/dist/bin.js",
		"dev:ama-bot": "turbo run build --filter=@chatsift/ama-bot && dotenv -e .env.private -e .env.public -- node --enable-source-maps ./services/ama-bot/dist/bin.js",
		"db:migrate": "dotenv -e .env.private -e .env.public -- yarn workspace @chatsift/db run db:migrate",
		"db:migrate:down": "dotenv -e .env.private -e .env.public -- yarn workspace @chatsift/db run db:migrate:down",
		"db:gen": "dotenv -e .env.private -e .env.public -- yarn workspace @chatsift/db run db:gen",
		"db:diff": "dotenv -e .env.private -e .env.public -- yarn workspace @chatsift/db run db:diff",
		"postinstall": "is-ci || husky || true",
		"update": "yarn upgrade-interactive"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-angular": "^21.2.0",
		"@types/lodash.merge": "^4.6.9",
		"@types/node": "^24.9.1",
		"@vitest/coverage-v8": "^4.1.10",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.39.5",
		"eslint-config-neon": "^0.5.4",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"husky": "^9.1.7",
		"is-ci": "^4.1.0",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.9.5",
		"rimraf": "^6.1.3",
		"turbo": "^2.10.5",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.64.0",
		"vitest": "^4.1.10"
	},
	"volta": {
		"node": "24.14.0"
	}
}

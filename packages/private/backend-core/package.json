{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@chatsift/backend-core",
	"version": "0.1.0",
	"description": "Core backend utilities",
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"types": "./dist/index.d.ts",
	"scripts": {

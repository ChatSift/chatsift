{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"lint:fix": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"clean": {
			"cache": false
		},
		"db:gen": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:migrate:down": {
			"cache": false
		},
		"db:diff": {
			"cache": false
		},
		"tag-docker": {
			"dependsOn": ["^build"],
			"outputs": [],
			"inputs": [
				"src/**/*.ts",
				"$TURBO_ROOT$/Dockerfile",
				"$TURBO_ROOT$/docker-compose.yml",
				"$TURBO_ROOT$/.env.public",
				"$TURBO_ROOT$/compose/**"
			]
		}
	},
	"globalDependencies": ["eslint.config.js", ".prettierrc.json", "tsconfig.json", "tsconfig.*.json", "vitest.config.ts"]
}
